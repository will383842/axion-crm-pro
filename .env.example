# =============================================================================
# Axion CRM Pro — .env.example
# Copier vers .env (gitignored) et adapter
# =============================================================================

# --- Mode mocks (Sprint 1-12 par défaut) -------------------------------------
MOCK_MODE=true
MOCK_LLM=true
MOCK_PROXIES=true
MOCK_SCRAPERS=true
MOCK_SMTP=true
MOCK_CAPTCHA=true
MOCK_INSEE=false
MOCK_ANNUAIRE_ENTREPRISES=false
MOCK_BODACC=false
MOCK_BAN=false
MOCK_FRANCE_TRAVAIL=false

# --- Laravel core ------------------------------------------------------------
APP_NAME="Axion CRM Pro"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://api.localhost
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_TIMEZONE=Europe/Paris

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Database ----------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=axion_crm
DB_USERNAME=axion
DB_PASSWORD=axion_dev_only
DB_SCHEMA=public

# --- Cache + Queues + Sessions -----------------------------------------------
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_DOMAIN=.localhost
SESSION_SAME_SITE=lax
SESSION_SECURE_COOKIE=false

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_QUEUE_DB=1
REDIS_CACHE_DB=2
HORIZON_PREFIX=horizon:axion-crm:

# --- Sanctum SPA -------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=app.localhost,localhost,127.0.0.1
SESSION_COOKIE=axion_crm_session
FRONTEND_URL=https://app.localhost

# --- Owner initial (utilisé une seule fois par OwnerUserSeeder) --------------
OWNER_INITIAL_EMAIL=williamsjullin@gmail.com
OWNER_INITIAL_NAME="Williams Jullin"
OWNER_INITIAL_PASSWORD=

# --- LLM providers (placeholders, ignorés en MOCK_MODE) ----------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=

# --- Proxies (placeholders, ignorés en MOCK_MODE) ---------------------------
WEBSHARE_API_KEY=
IPROYAL_API_KEY=
TWOCAPTCHA_API_KEY=

# --- Brave Search API (Sprint H1 — remplace DuckDuckGo scrape) ---------------
# https://api.search.brave.com/app/keys — 2000 req/mois free, $5/1K ensuite
BRAVE_SEARCH_API_KEY=

# --- Hunter.io email verification (Sprint H2) --------------------------------
# https://hunter.io/api-keys — 25 vérifs/mois free, $34/mo plan Starter 1K
HUNTER_API_KEY=

# --- Webshare proxies pour Pages Jaunes (Sprint H1, Phase B uniquement) ------
# Désactivé par défaut, activer après validation Phase A Will (~$30/mo flat)
WEBSHARE_ENABLED=false
WEBSHARE_USERNAME=
WEBSHARE_PASSWORD=
WEBSHARE_ENDPOINT=p.webshare.io:80

# --- Google Places API (Sprint H9 + H12 + H14, recommandé Phase A) -----------
# Enrichissement auto téléphone/website/horaires/note Google. Free tier ~12K
# lookups/mois grâce au crédit Maps Platform $200/mois. Console GCP :
# https://console.cloud.google.com/ → projet axion-crm-pro → Places API (New)
GOOGLE_PLACES_API_KEY=
# Cache des réponses Google Places (default 30 jours)
GOOGLE_PLACES_CACHE_TTL_DAYS=30
# Sprint H12 — Hard cap mensuel d'appels (default 11500, marge 500 sur 12K free)
# Au-delà : skip + marker signals.google_places_pending pour retry mois suivant
GOOGLE_PLACES_MONTHLY_QUOTA_LIMIT=11500
# Sprint H14 — Smart skip : ne pas appeler Google Places si entreprise a déjà
# email exploitable + phone + website (économise quota pour les cas vraiment utiles)
GOOGLE_PLACES_SMART_SKIP=true
# Sprint H14 — Seuil au-delà duquel le KpiCard /admin/observability passe en alerte rose
GOOGLE_PLACES_PENDING_ALERT_THRESHOLD=5000

# --- EmailFinder spéculatif (Sprint H7, politique Will : OFF par défaut) -----
# Si true : EmailFinderService génère 18 patterns spéculatifs (jean.dupont@...).
# Activer UNIQUEMENT si un vrai vérificateur SMTP externe (Hunter/ZeroBounce)
# est wired pour valider les candidats. Sinon laisser false (doctrine "0 email
# douteux" : la base ne contient QUE les emails réels scrapés mentions-légales).
EMAIL_FINDER_SPECULATIVE_ENABLED=false

# --- Santé / RPPS (Annuaire Santé « PS LibreAccès ») ------------------------
# Verticale santé : spécialité médicale + tél des pros de santé (rpps:import).
# ⚠️ Donnée nominative de SANTÉ (RGPD art. 9). L'import RÉEL est REFUSÉ tant que
# SANTE_INGESTION_ENABLED=false. N'activer qu'APRÈS validation de l'AIPD dédiée.
SANTE_INGESTION_ENABLED=false
# MOCK_RPPS=true en dev → rpps:import seede des praticiens fictifs (défaut MOCK_MODE).
MOCK_RPPS=true

# --- INSEE Sirene (gratuit, recommandé activer) -----------------------------
# Choisir UN des 2 modes selon plan souscrit sur portail-api.insee.fr :
# Mode 1 (Accès public, 30 req/min) : ne remplir QUE INSEE_API_KEY
INSEE_API_BASE_URL=https://api.insee.fr
INSEE_API_KEY=
# Mode 2 (Accès authentifié OAuth2, 500 req/min) : ne remplir QUE les 2 vars ci-dessous
INSEE_CLIENT_ID=
INSEE_CLIENT_SECRET=

# --- annuaire-entreprises ----------------------------------------------------
ANNUAIRE_ENTREPRISES_BASE_URL=https://recherche-entreprises.api.gouv.fr
BODACC_BASE_URL=https://bodacc-datafluide.opendatasoft.com
BAN_BASE_URL=https://api-adresse.data.gouv.fr
FRANCE_TRAVAIL_BASE_URL=https://api.francetravail.io

# --- SMTP probe --------------------------------------------------------------
SMTP_PROBE_FROM_DOMAIN=axion-crm.local
SMTP_PROBE_FROM_EMAIL=postmaster@axion-crm.local
SMTP_PROBE_TIMEOUT_S=8

# --- Telemetry / Observability ------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=axion-crm-backend
GLITCHTIP_DSN=

# --- Sécurité ----------------------------------------------------------------
AUDIT_HASH_CHAIN_SECRET=
RATE_LIMIT_PER_MINUTE=60
SSRF_GUARD_DENY_PRIVATE=true

# --- Frontend (Vite, prefix VITE_) -------------------------------------------
VITE_API_BASE_URL=https://api.localhost
VITE_APP_NAME="Axion CRM Pro"
VITE_MAPLIBRE_TILES_URL=https://tiles.openfreemap.org/styles/liberty
VITE_SENTRY_DSN=

# --- Workers (Node) ----------------------------------------------------------
WORKER_TYPE=google-maps
WORKER_CONCURRENCY=2
WORKER_REDIS_URL=redis://redis:6379/1
WORKER_INTERNAL_HMAC_SECRET=
WORKER_INTERNAL_RESULT_URL=http://api:80/internal/scraper-result
