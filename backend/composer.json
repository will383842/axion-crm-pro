{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "axion-ia/axion-crm-pro-backend",
    "type": "project",
    "description": "Axion CRM Pro — backend Laravel 12 (B2B prospection automatisée).",
    "keywords": ["laravel", "axion", "crm", "scraping", "b2b"],
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "ext-pdo": "*",
        "ext-pgsql": "*",
        "ext-redis": "*",
        "ext-bcmath": "*",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7.9",
        "laravel/framework": "^12.0",
        "laravel/horizon": "^5.27",
        "laravel/reverb": "^1.4",
        "laravel/sanctum": "^4.0",
        "laravel/telescope": "^5.4",
        "laravel/tinker": "^2.10",
        "predis/predis": "^2.2",
        "pragmarx/google2fa": "^8.0",
        "pragmarx/google2fa-laravel": "^2.2",
        "bacon/bacon-qr-code": "^3.0",
        "spatie/laravel-data": "^4.10",
        "spatie/laravel-permission": "^6.10",
        "spatie/laravel-model-states": "^2.8",
        "spatie/laravel-query-builder": "^6.2",
        "league/csv": "^9.16",
        "smalot/pdfparser": "^2.10",
        "open-telemetry/opentelemetry": "^1.0",
        "open-telemetry/exporter-otlp": "^1.0",
        "open-telemetry/sdk": "^1.0",
        "darkaonline/l5-swagger": "^9.0",
        "sentry/sentry-laravel": "^4.10"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.18",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.5",
        "pestphp/pest": "^3.7",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/phpstan": "^2.0",
        "larastan/larastan": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "test": "pest --colors",
        "lint": "pint",
        "analyse": "phpstan analyse --memory-limit=2G"
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
