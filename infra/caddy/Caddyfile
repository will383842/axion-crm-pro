# Axion CRM Pro — Caddy reverse proxy local
# api.localhost  → backend Laravel
# app.localhost  → frontend Vite dev / nginx prod
{
    auto_https off
    local_certs
}

api.localhost {
    encode zstd gzip
    reverse_proxy api:80 {
        header_up X-Forwarded-Proto {scheme}
        header_up X-Real-IP {remote_host}
    }
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(self), microphone=(), camera=(), interest-cohort=()"
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://api.localhost wss://api.localhost; font-src 'self' data:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        Cross-Origin-Opener-Policy "same-origin"
        Cross-Origin-Resource-Policy "same-site"
    }
}

app.localhost {
    encode zstd gzip
    reverse_proxy app:5173 {
        header_up X-Forwarded-Proto {scheme}
        # WebSocket HMR
        header_up Connection {>Connection}
        header_up Upgrade {>Upgrade}
    }
}
