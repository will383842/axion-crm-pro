# Axion CRM Pro — Caddy reverse proxy
# Dev local : api.localhost / app.localhost (cert auto-signe via tls internal)
# Prod : app.axion-crm-pro.com (single origin : /api + /sanctum -> backend, reste -> frontend)
#        api.axion-crm-pro.com (backend direct pour curl/debug)

{
    email williamsjullin@gmail.com
    servers {
        trusted_proxies static private_ranges
    }
}

# --- DEV : API Laravel ------------------------------------------------------
api.localhost {
    tls internal
    encode zstd gzip
    reverse_proxy api:80 {
        header_up X-Real-IP {remote_host}
    }
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(self), microphone=(), camera=(), interest-cohort=(), browsing-topics=()"
        Content-Security-Policy "default-src 'none'; connect-src 'self'; frame-ancestors 'none'; base-uri 'none'; form-action 'none'"
        Cross-Origin-Opener-Policy "same-origin"
        Cross-Origin-Resource-Policy "same-site"
        Cache-Control "no-store"
    }
    @docs path /docs /docs/*
    header @docs {
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; font-src 'self' data:"
    }
}

# --- DEV : Frontend SPA -----------------------------------------------------
app.localhost {
    tls internal
    encode zstd gzip
    reverse_proxy app:5173 {
        header_up Connection {>Connection}
        header_up Upgrade {>Upgrade}
    }
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(self), microphone=(), camera=(), interest-cohort=(), browsing-topics=()"
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:; connect-src 'self' https://api.localhost wss://api.localhost https://*.openfreemap.org wss://app.localhost; font-src 'self' data:; worker-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        Cross-Origin-Opener-Policy "same-origin"
        Cross-Origin-Resource-Policy "same-site"
    }
}

# --- PROD : app.axion-crm-pro.com — SINGLE ORIGIN (frontend + API path-routed)
# Evite les third-party cookies (Chrome 2026 default block).
app.axion-crm-pro.com {
    encode zstd gzip

    # Routes API -> backend Laravel
    @api {
        path /api/* /sanctum/* /docs /docs/* /up /broadcasting/*
    }
    handle @api {
        reverse_proxy api:80 {
            header_up X-Real-IP {remote_host}
        }
    }

    # Tout le reste -> frontend Vite
    handle {
        reverse_proxy app:5173 {
            header_up Connection {>Connection}
            header_up Upgrade {>Upgrade}
        }
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}

# --- PROD : api.axion-crm-pro.com — backend direct (curl/debug)
api.axion-crm-pro.com {
    encode zstd gzip
    reverse_proxy api:80 {
        header_up X-Real-IP {remote_host}
    }
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}
