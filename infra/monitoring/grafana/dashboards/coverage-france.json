{
  "title": "Axion CRM Pro — Coverage France",
  "tags": ["axion", "coverage"],
  "schemaVersion": 39,
  "refresh": "5m",
  "time": { "from": "now-30d", "to": "now" },
  "panels": [
    { "id": 1, "title": "Entreprises totales", "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "axion_crm_companies_total" }] },
    { "id": 2, "title": "Fresh + complete prospects", "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "axion_crm_fresh_complete_prospects_gauge" }] },
    { "id": 3, "title": "Distribution par taille", "type": "piechart",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [{ "expr": "axion_crm_size_category_distribution" }] },
    { "id": 4, "title": "Enrichment velocity / day", "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [{ "expr": "rate(axion_crm_companies_enriched_total[1d])" }] }
  ]
}
