{
  "title": "Axion CRM Pro — Postgres",
  "tags": ["axion", "db", "postgres"],
  "schemaVersion": 39,
  "refresh": "30s",
  "panels": [
    { "id": 1, "title": "Connexions actives", "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [{ "expr": "pg_stat_activity_count" }] },
    { "id": 2, "title": "Cache hit ratio", "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "pg_stat_database_blks_hit / (pg_stat_database_blks_hit + pg_stat_database_blks_read)" }] },
    { "id": 3, "title": "DB size", "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "pg_database_size_bytes" }] },
    { "id": 4, "title": "Lock waits", "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [{ "expr": "pg_locks_count{mode!=\"AccessShareLock\"}" }] }
  ]
}
