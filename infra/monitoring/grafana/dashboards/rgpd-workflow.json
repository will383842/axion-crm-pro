{
  "title": "Axion CRM Pro — RGPD workflow",
  "tags": ["axion", "rgpd", "compliance"],
  "schemaVersion": 39,
  "refresh": "5m",
  "panels": [
    { "id": 1, "title": "Requêtes pending", "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "axion_crm_rgpd_pending_total" }] },
    { "id": 2, "title": "Erasure count 30j", "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "increase(axion_crm_rgpd_erasure_total[30d])" }] },
    { "id": 3, "title": "Temps moyen traitement", "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "histogram_quantile(0.5, axion_crm_rgpd_processing_duration_seconds_bucket)" }] }
  ]
}
