{
  "title": "Axion CRM Pro — Workers Playwright",
  "tags": ["axion", "workers"],
  "schemaVersion": 39,
  "refresh": "30s",
  "panels": [
    { "id": 1, "title": "Worker up", "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(worker_up)" }] },
    { "id": 2, "title": "Last job seconds ago", "type": "timeseries",
      "gridPos": { "x": 6, "y": 0, "w": 12, "h": 8 },
      "targets": [{ "expr": "worker_last_job_seconds_ago" }] },
    { "id": 3, "title": "Memory usage", "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [{ "expr": "process_resident_memory_bytes{job=\"workers\"}" }] }
  ]
}
