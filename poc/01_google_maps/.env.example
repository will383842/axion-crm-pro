# IPRoyal residential proxies (pay-as-you-go)
# Format gateway IPRoyal : geo.iproyal.com:12321
# Username avec extensions : <user>_country-fr_session-<id>_lifetime-30m
IPROYAL_USERNAME=REPLACE_ME
IPROYAL_PASSWORD=REPLACE_ME
IPROYAL_GATEWAY=geo.iproyal.com:12321

# Optionnel : Webshare datacenter fallback
WEBSHARE_PROXIES_FILE=./proxies-webshare.txt

# Limites
ENTREPRISES_PER_DAY=1000
CONCURRENCY=2                  # Sessions Playwright simultanées (CPX31 = 2 max)
COOLDOWN_BETWEEN_SCRAPES_MS=15000   # Politesse Google : 15s entre searches
TIMEOUT_PAGE_MS=25000
