# Anthropic API
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
ANTHROPIC_MODEL=claude-haiku-4-5

# Webshare proxies (1 ligne = 1 proxy au format user:pass@host:port)
# Récupère depuis dashboard Webshare → Proxy List → Download
# Pour le POC, 1-5 proxies suffisent
WEBSHARE_PROXIES_FILE=./proxies.txt

# Limites
MAX_ETIS=20
MAX_PAGES_PER_ETI=15
TIMEOUT_PAGE_MS=20000
LLM_MAX_TOKENS=600
