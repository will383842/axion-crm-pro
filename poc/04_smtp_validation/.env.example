# Email "from" utilisé pour le probe SMTP MAIL FROM:<>
# IMPORTANT : doit être un domaine que TU contrôles (sinon classé spammer).
# Si tu as axion-pro.com configuré : VALIDATOR_FROM_EMAIL=validator@axion-pro.com
# Sinon utiliser un domaine perso temporaire ou bounce-friendly (jamais gmail/hotmail)
VALIDATOR_FROM_EMAIL=validator@example.com

# Domaine annoncé en HELO/EHLO — souvent le même que from
VALIDATOR_HELO_DOMAIN=example.com

# Timeouts (millisecondes)
TIMEOUT_CONNECT_MS=10000
TIMEOUT_COMMAND_MS=5000

# Concurrence (combien de probes en parallèle)
CONCURRENCY=5
