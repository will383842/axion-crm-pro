# Postgres local Docker — valeurs par défaut OK pour le POC
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=axion
PGPASSWORD=poc_local_only
PGDATABASE=axion_poc05

# Paramètres benchmark
SEED_ROWS_TOTAL=10000000     # 10 millions de rows scraper_runs
SEED_COMPANIES=100000        # 100k entreprises distinctes
SEED_MONTHS=12               # 12 partitions mensuelles
BENCHMARK_QUERIES=10000      # nombre de queries dedup à exécuter
BENCHMARK_CONCURRENCY=10     # connexions parallèles
